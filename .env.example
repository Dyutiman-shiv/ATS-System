# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Environment: dev / demo / prod
APP_ENV=demo

# Email (SMTP2GO)
EMAIL_HOST=mail.smtp2go.com
EMAIL_PORT=2525
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
SMTP2GO_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Production Database (used when APP_ENV=prod)
PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_HOST=
PROD_DB_PORT=

# Production email
PROD_DEFAULT_FROM_EMAIL=HireQ.ai <support@hireq.ai>
DEV_DEFAULT_FROM_EMAIL=

# Base URLs
PROD_BASE_URL=https://www.hireq.ai/
DEV_BASE_URL=http://127.0.0.1:8000/
